generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String        @id @default(uuid())
  fullName         String
  email            String        @unique
  role             Role          @default(WORKER)
  city             String
  deliveryPlatform String
  vehicleType      String
  weeklyEarnings   Int
  upiId            String?
  trustScore       Float         @default(1.0)
  isVerified       Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  phoneNumber      String?
  claims           Claim[]
  policies         Policy[]
  sessions         WorkSession[]
  treasuryTransactions TreasuryTransaction[] @relation("TreasuryActionBy")
}

model OtpVerification {
  id        String   @id @default(uuid())
  email     String
  otpCode   String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Policy {
  id                String       @id @default(uuid())
  userId            String
  planTier          PlanTier
  status            PolicyStatus
  coverageAmount    Int
  premiumPaid       Int
  razorpayOrderId   String?      @unique
  razorpayPaymentId String?      @unique
  startDate         DateTime     @default(now())
  endDate           DateTime
  createdAt         DateTime     @default(now())
  claims            Claim[]
  user              User         @relation(fields: [userId], references: [id])

  @@index([status, userId])
}

model WorkSession {
  id                  String           @id @default(uuid())
  userId              String
  startTime           DateTime         @default(now())
  endTime             DateTime?
  activeMinutes       Int              @default(0)
  ipAddress           String
  ipCity              String?
  platformActiveFlag  Boolean          @default(true)
  sessionHash         String
  previousSessionHash String?
  heartbeats         WorkHeartbeat[] // Relation to individual 60s pulses
  createdAt           DateTime        @default(now())
  user                User             @relation(fields: [userId], references: [id])

  @@index([userId, startTime(sort: Desc)])
}

model WorkHeartbeat {
  id        String   @id @default(uuid())
  sessionId String
  timestamp DateTime @default(now())
  ipAddress String
  hash      String
  session   WorkSession @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
}

model EnvironmentalEvent {
  id         String   @id @default(uuid())
  city       String
  eventType  String
  alertLevel String
  intensity  Float
  source     String
  timestamp  DateTime @default(now())
}

model Claim {
  id               String      @id @default(uuid())
  userId           String
  policyId         String
  triggerEvent     String
  status           ClaimStatus
  fraudScore       Float?
  workProofScore   Float?
  behavioralScore  Float?
  isChainValid     Boolean     @default(true)
  payoutAmount     Int?
  razorpayPayoutId String?     @unique
  reviewerNotes    String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  policy           Policy      @relation(fields: [policyId], references: [id])
  user             User        @relation(fields: [userId], references: [id])

  @@index([userId, status])
}

model Treasury {
  id           String                @id @default(uuid())
  name         String                @unique @default("PRIMARY_TREASURY")
  balance      Int                   @default(0)
  currency     String                @default("INR")
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  transactions TreasuryTransaction[]
}

model TreasuryTransaction {
  id              String                    @id @default(uuid())
  treasuryId      String
  direction       TreasuryDirection
  type            TreasuryTransactionType
  amount          Int
  balanceAfter    Int
  referenceType   String?
  referenceId     String?
  note            String?
  createdByUserId String?
  createdAt       DateTime                  @default(now())
  treasury        Treasury                  @relation(fields: [treasuryId], references: [id])
  createdBy       User?                     @relation("TreasuryActionBy", fields: [createdByUserId], references: [id])

  @@index([treasuryId, createdAt(sort: Desc)])
  @@index([referenceType, referenceId])
}

enum Role {
  WORKER
  ADMIN
}

enum PlanTier {
  BASIC
  STANDARD
  PREMIUM
}

enum PolicyStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum ClaimStatus {
  PENDING
  PAID
  REVIEW
  REJECTED
  APPEALED
}

enum TreasuryDirection {
  CREDIT
  DEBIT
}

enum TreasuryTransactionType {
  PREMIUM
  PAYOUT
  TOPUP
  ADJUSTMENT
}
